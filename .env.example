# ─── Database ────────────────────────────────────────────────────────────────
# Vercel Postgres: copy the value of POSTGRES_PRISMA_URL from your Vercel project
DATABASE_URL="postgresql://user:password@host:5432/draughts?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Your production URL (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# ─── Admin Seed Credentials ───────────────────────────────────────────────────
# Used ONLY by prisma/seed.ts — change immediately after first login
ADMIN_EMAIL="admin@draughtsndragons.com"
ADMIN_PASSWORD="changeme123"

# ─── One-Time Seed Route ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# POST /api/admin/seed with Authorization: Bearer <SEED_SECRET> after first deploy
SEED_SECRET="your-seed-secret-here"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 100 emails/day, 3 000/month
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Verified sender address (must match a domain you've verified in Resend)
EMAIL_FROM="Draughts & Dragons <noreply@yourdomain.com>"

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# Shared secret used to authenticate calls to /api/jobs/*
# Generate with: openssl rand -base64 32
# On Vercel: set this and it is sent automatically by Vercel Cron.
# For local testing: pass as  Authorization: Bearer <CRON_SECRET>
CRON_SECRET="your-cron-secret-here"
